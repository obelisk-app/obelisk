generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Server {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  banner      String?
  ownerPubkey String
  joinMode    String   @default("open") // open | invite-only
  createdAt   DateTime @default(now())

  // Web of Trust (anti-spam): when wotEnabled, only users followed by referentePubkey
  // (or in WotOverride, or holding a valid invite) can join. joinMode is ignored.
  referentePubkey    String?
  wotEnabled         Boolean   @default(false)
  referenteFetchedAt DateTime?

  // Member invite credits: members with tenure >= minDaysActive days can
  // create up to invitesPerUser single-use invites that auto-expire after
  // inviteExpiryHours. Set invitesPerUser=0 to disable member invites.
  minDaysActive     Int @default(7)
  invitesPerUser    Int @default(3)
  inviteExpiryHours Int @default(168) // 7 days

  // Welcome bot: admin-configurable channel + language for auto-welcome on join.
  // welcomeChannelId null OR welcomeLocale null => bot disabled.
  welcomeChannelId String?  @unique
  welcomeLocale    String? // 'es' | 'en'
  welcomeChannel   Channel? @relation("ServerWelcomeChannel", fields: [welcomeChannelId], references: [id], onDelete: SetNull)

  // Landing channel: where brand-new members land on their first `/chat` load
  // for this server. Distinct from welcomeChannelId (which is the welcome-bot
  // channel that auto-posts a greeting). A channel can serve both roles or
  // neither. Nulled automatically if the channel is deleted.
  landingChannelId String?  @unique
  landingChannel   Channel? @relation("ServerLandingChannel", fields: [landingChannelId], references: [id], onDelete: SetNull)

  // Per-server upload limits. Defaults match the global constants in
  // src/lib/attachments.ts. allowedMimeTypes is an optional JSON-encoded
  // string array; null means "use the global allowlist". Absolute ceiling
  // (500 MB) is enforced server-side independently.
  maxImageBytes    Int     @default(10485760) // 10 MB
  maxVideoBytes    Int     @default(52428800) // 50 MB
  maxDocBytes      Int     @default(26214400) // 25 MB
  maxAudioBytes    Int     @default(26214400) // 25 MB
  allowedMimeTypes String?

  categories           Category[]
  channels             Channel[]
  members              Member[]
  bans                 Ban[]
  mutes                Mute[]
  warnings             Warning[]
  reports              Report[]
  moderationActions    ModerationAction[]
  invitations          Invitation[]
  wotEntries           WotEntry[]
  wotOverrides         WotOverride[]
  emojis               ServerEmoji[]
  gifs                 ServerGif[]
  customRoles          CustomRole[]
  bots                 ServerBot[]
  isDefaultForInstance InstanceSettings?  @relation("InstanceDefaultServer")
}

// Prebuilt, per-server "bots" that surface as pseudo-members in the right
// sidebar. They don't post messages; their current value is shown inline as
// status text next to the bot's name. See `src/lib/bots/registry.ts` for the
// type → fetcher mapping and `src/lib/bots/poller.ts` for the refresh loop.
model ServerBot {
  id          String    @id @default(cuid())
  serverId    String
  type        String // "btc-usd" | "sats-ars" | "peronio-ars" | "dolar-ars"
  enabled     Boolean   @default(true)
  displayName String? // override, else registry default
  avatarUrl   String? // override, else registry default
  lastValue   String? // last rendered status, e.g. "$63,412"
  lastFetchAt DateTime?
  createdAt   DateTime  @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, type])
  @@index([serverId])
}

// Custom per-server emoji (`:partyparrot:` style). Uploaded by mod+ via
// /api/admin/emojis. Rendered inline in messages/reactions when a shortcode
// matches a name stored here. See `src/lib/emoji-shortcodes.ts` for the
// unicode fallback and `src/components/chat/MessageContent.tsx` for the
// render-time swap.
model ServerEmoji {
  id        String   @id @default(cuid())
  serverId  String
  name      String // [a-z0-9_-]{2,32}, no colons
  url       String
  createdBy String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

// Curated per-server GIF library. Uploaded by mod+ via /api/admin/gifs and
// shown in the composer's GIF picker. Unlike ServerEmoji, GIFs are full-size
// images inserted into messages as URLs (rendered inline via the existing
// image-gallery pipeline in MessageContent). `tags` is a comma-separated list
// used by the picker's search.
model ServerGif {
  id         String   @id @default(cuid())
  serverId   String
  name       String // free-form label (2–64 chars), displayed in picker
  url        String // /uploads/<id>.gif — hosted by our own upload route
  tags       String   @default("") // comma-separated, lowercased
  width      Int?
  height     Int?
  sizeBytes  Int?
  uploadedBy String
  createdAt  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([serverId, createdAt])
}

model DirectMessageThread {
  id           String   @id @default(cuid())
  participant1 String // pubkey (sorted: participant1 < participant2)
  participant2 String
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([participant1, participant2])
  @@index([participant1])
  @@index([participant2])
}

model Invitation {
  id            String    @id @default(cuid())
  serverId      String
  code          String    @unique
  createdBy     String // pubkey of inviter
  targetPubkey  String? // null = anyone, set = specific npub
  maxUses       Int       @default(1)
  uses          Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  revokedAt     DateTime? // soft-revoke: null = active, set = no new joins but history preserved
  revokedBy     String? // pubkey of admin who revoked
  // True when this invite was minted against the creator's member credit pool
  // (tenure-based). Admin-minted invites stay false regardless of who created
  // them, so an admin who also holds a member row doesn't see admin invites
  // bleeding into their "My Invites" card or eating member credits.
  memberCreated Boolean   @default(false)

  server  Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members Member[] @relation("InvitationMembers")

  @@index([serverId])
  @@index([code])
  @@index([serverId, createdBy, memberCreated])
}

model Category {
  id       String @id @default(cuid())
  serverId String
  name     String
  position Int    @default(0)

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels Channel[]

  @@index([serverId])
}

model Channel {
  id              String   @id @default(cuid())
  serverId        String
  categoryId      String?
  name            String
  emoji           String?
  description     String?
  type            String   @default("text") // text | voice | forum
  // Voice-only: "mesh" (P2P, ≤8 participants) or "sfu" (LiveKit, large rooms).
  // Ignored for non-voice channels.
  voiceMode       String?  @default("mesh")
  position        Int      @default(0)
  writePermission String? // null = everyone; "mod" | "admin" | "roles"
  writeRoleIds    String[] @default([]) // used when writePermission = "roles"
  readPermission  String? // null = everyone; "mod" | "admin" | "roles"
  readRoleIds     String[] @default([]) // used when readPermission = "roles"
  createdAt       DateTime @default(now())
  // Denormalized timestamp of the most recent message. Bumped on every
  // message insert; used by unread-aggregation queries to avoid counting
  // messages on every sidebar render.
  lastMessageAt   DateTime?

  server           Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages         Message[]
  voiceStates      VoiceState[]
  forumTags        ForumTag[]
  readStates       ChannelReadState[]
  welcomeForServer Server?            @relation("ServerWelcomeChannel")
  landingForServer Server?            @relation("ServerLandingChannel")

  @@index([serverId])
  @@index([categoryId])
  @@index([serverId, lastMessageAt])
}

// Global instance settings. There will only ever be one row with id="global".
model InstanceSettings {
  id              String  @id @default("global")
  defaultServerId String? @unique

  defaultServer Server? @relation("InstanceDefaultServer", fields: [defaultServerId], references: [id], onDelete: SetNull)
}

model VoiceState {
  id        String   @id @default(cuid())
  channelId String
  pubkey    String
  muted     Boolean  @default(false)
  deafened  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, pubkey])
  @@index([channelId])
}

model Message {
  id           String    @id @default(cuid())
  channelId    String
  authorPubkey String
  title        String? // null for chat messages, set for forum posts
  coverImage   String? // optional cover image URL for forum posts (null otherwise)
  content      String
  replyToId    String?
  createdAt    DateTime  @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?

  // Pinning (admin-only). Mirrors the editedAt pattern — pinnedAt null means
  // the message is not pinned. pinnedByPubkey records who pinned it last.
  pinnedAt       DateTime?
  pinnedByPubkey String?

  channel   Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo   Message?            @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]           @relation("MessageReplies")
  reports   Report[]
  reactions Reaction[]
  tags      ForumTagOnMessage[]
  mentions  Mention[]

  @@index([channelId, createdAt])
  @@index([authorPubkey])
  @@index([channelId, pinnedAt])
}

model Reaction {
  id           String   @id @default(cuid())
  messageId    String
  authorPubkey String
  emoji        String
  createdAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, authorPubkey, emoji])
  @@index([messageId])
}

model ForumTag {
  id        String @id @default(cuid())
  channelId String
  name      String
  color     String @default("#b4f953") // hex color for the tag pill
  position  Int    @default(0)

  channel  Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ForumTagOnMessage[]

  @@unique([channelId, name])
  @@index([channelId])
}

model ForumTagOnMessage {
  id        String @id @default(cuid())
  messageId String
  tagId     String

  message Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tag     ForumTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([messageId, tagId])
  @@index([messageId])
  @@index([tagId])
}

// Subscription (follow) of a pubkey to a forum post. Replaces the previous
// localStorage-backed follow model. Enables cross-device follow + server-side
// notification fan-out on replies.
model PostSubscription {
  id         String    @id @default(cuid())
  postId     String
  pubkey     String
  createdAt  DateTime  @default(now())
  // Last time the subscriber opened the post's chat view. Replies created
  // after this timestamp count as unread for notification fan-out.
  lastReadAt DateTime?

  @@unique([postId, pubkey])
  @@index([pubkey])
  @@index([postId])
}

model Member {
  id       String   @id @default(cuid())
  serverId String
  pubkey   String
  role     String   @default("member") // owner | admin | mod | member
  joinedAt DateTime @default(now())

  // Cached Nostr profile data
  displayName      String?
  picture          String?
  nip05            String?
  about            String?
  banner           String?
  lud16            String?
  website          String?
  nickname         String? // Obelisk-local server nickname override
  profileUpdatedAt DateTime?

  // Activity tracking for invite-credit eligibility (anti-sybil)
  lastActivityAt DateTime?

  // First-visit landing redirect marker. False until this member's first
  // `/chat` load resolves an initial channel; then flipped to true so the
  // landing-channel redirect runs at most once per member per server.
  hasEnteredChat Boolean @default(false)

  // Source tracking — when set, this member joined via the given invite link.
  // Surfaced in the admin panel so owners can see who came from where.
  joinedViaInviteId String?
  joinedViaInvite   Invitation? @relation("InvitationMembers", fields: [joinedViaInviteId], references: [id], onDelete: SetNull)

  server      Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  customRoles MemberCustomRole[]

  @@unique([serverId, pubkey])
  @@index([serverId])
  @@index([pubkey])
  @@index([joinedViaInviteId])
}

model Session {
  id        String   @id @default(cuid())
  pubkey    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([pubkey])
  @@index([token])
}

model Ban {
  id             String   @id @default(cuid())
  serverId       String
  pubkey         String
  bannedByPubkey String
  reason         String?
  createdAt      DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
}

model Mute {
  id            String   @id @default(cuid())
  serverId      String
  targetPubkey  String
  mutedByPubkey String
  expiresAt     DateTime
  reason        String?
  createdAt     DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, targetPubkey])
}

model Warning {
  id             String   @id @default(cuid())
  serverId       String
  targetPubkey   String
  issuedByPubkey String
  reason         String
  createdAt      DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, targetPubkey])
}

model Report {
  id               String    @id @default(cuid())
  serverId         String
  messageId        String
  reporterPubkey   String
  reason           String
  status           String    @default("pending") // pending | resolved | dismissed
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  resolvedByPubkey String?

  server  Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
}

model ModerationAction {
  id           String   @id @default(cuid())
  serverId     String
  actorPubkey  String
  targetPubkey String?
  action       String // ban | unban | kick | mute | unmute | warn | delete_message | role_change
  reason       String?
  metadata     String? // JSON string for extra data
  createdAt    DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

model ChannelReadState {
  id                   String    @id @default(cuid())
  channelId            String
  pubkey               String
  lastReadAt           DateTime  @default(now())
  lastReadMessageId    String?
  // Separate cursor for the mention badge — lets us clear the "you were
  // mentioned" dot as soon as the user opens the channel (even when they're
  // scrolled up / not near bottom), without pretending they've read every
  // message in between. `/api/unread` filters `Mention.createdAt >
  // (lastMentionReadAt ?? lastReadAt)`.
  lastMentionReadAt    DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, pubkey])
  @@index([pubkey])
}

model Mention {
  id        String   @id @default(cuid())
  messageId String
  pubkey    String
  channelId String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, pubkey])
  @@index([pubkey, createdAt])
  @@index([channelId, pubkey])
}

model DMReadState {
  id           String   @id @default(cuid())
  pubkey       String
  threadPubkey String
  lastReadAt   DateTime @default(now())

  @@unique([pubkey, threadPubkey])
}

// Per-user per-scope notification settings (Discord/Slack model).
// scopeType ∈ {server, category, channel, dm}. notifyLevel null means
// "inherit from parent" (channel → category → server default). mutedUntil
// is orthogonal: a null notifyLevel + non-null mutedUntil still suppresses
// UI noise without changing delivery semantics.
//
// Mentions are ALWAYS written to Mention/InboxItem regardless of the level
// here — this table only gates Socket.io push + toast + sidebar badges.
model NotificationPreference {
  id          String    @id @default(cuid())
  pubkey      String
  scopeType   String // "server" | "category" | "channel" | "dm"
  scopeId     String // serverId | categoryId | channelId | counterparty pubkey
  notifyLevel String? // "all" | "mentions" | "nothing" — null = inherit
  mutedUntil  DateTime? // null = not muted
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([pubkey, scopeType, scopeId])
  @@index([pubkey])
  @@index([scopeType, scopeId])
}

// Persisted notification inbox. Replaces the session-only client store so
// notifications survive reload / device switch. Populated by the mention
// fan-out pipeline alongside the existing Mention row; the two are NOT
// redundant — Mention drives channel-level mention badges (read via
// ChannelReadState.lastMentionReadAt cursor), InboxItem drives the global
// Inbox feed (read via per-row readAt).
model InboxItem {
  id              String    @id @default(cuid())
  recipientPubkey String
  type            String // "mention" | "reply" | "everyone" | "dm"
  serverId        String?
  channelId       String?
  messageId       String?
  postId          String?
  senderPubkey    String
  preview         String
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([recipientPubkey, createdAt])
  @@index([recipientPubkey, readAt])
}

// Cached follow list of a server's referente. Refreshed lazily on login + by admin.
model WotEntry {
  id       String   @id @default(cuid())
  serverId String
  pubkey   String
  addedAt  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
  @@index([pubkey])
}

// Manual whitelist for npubs not in the referente's WoT but explicitly allowed by admins.
model WotOverride {
  id        String   @id @default(cuid())
  serverId  String
  pubkey    String
  addedBy   String
  reason    String?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
}

// Custom roles per server (e.g. "VIP", "Artist", "Gold"). Layered on top of
// the base role (owner/admin/mod/member). A member can hold multiple custom
// roles; effective permissions = base role defaults | all custom role bits.
model CustomRole {
  id          String   @id @default(cuid())
  serverId    String
  name        String // display name, e.g. "Gold"
  color       String   @default("#99aab5") // hex color for badge + username tint
  icon        String? // emoji or image URL
  priority    Int      @default(0) // higher = shown first in member list
  permissions BigInt   @default(0) // bitfield, see src/lib/permissions.ts
  createdAt   DateTime @default(now())

  server  Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members MemberCustomRole[]

  @@unique([serverId, name])
  @@index([serverId])
}

// ── Games / Activities ──────────────────────────────────────────────
// Turn-based games scoped to a server. Created from the "Actividades"
// button in a voice channel or from any text channel via `/jugar`.
// State is JSON so new games can be added without schema churn.
model Game {
  id            String    @id @default(cuid())
  serverId      String
  channelId     String  // channel where the game was created
  type          String  // "tic-tac-toe" | ...
  status        String    @default("waiting") // waiting | in_progress | finished | cancelled
  minPlayers    Int
  maxPlayers    Int
  turnTimeoutS  Int       @default(30)
  currentTurn   String? // pubkey of active player, null when waiting/finished
  turnDeadline  DateTime?
  state         Json
  winnerPubkey  String?
  createdBy     String
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?

  participants GameParticipant[]

  @@index([serverId, status])
  @@index([channelId])
}

model GameParticipant {
  id       String   @id @default(cuid())
  gameId   String
  pubkey   String
  seat     Int
  status   String   @default("joined") // joined | disqualified | left
  joinedAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, pubkey])
  @@index([gameId])
  @@index([pubkey])
}

// Nostr Wallet Connect endpoint stored per pubkey. The `nwcUrlEncrypted`
// field holds an AES-256-GCM ciphertext of a `nostr+walletconnect://...`
// URL; see `src/lib/crypto.ts`. One wallet per user across all servers.
model Wallet {
  id               String   @id @default(cuid())
  pubkey           String   @unique
  nwcUrlEncrypted  String
  label            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([pubkey])
}

// Records a public BOLT11 invoice posted in chat that has been paid via NWC.
// Keyed by paymentHash so races between concurrent payers resolve as a
// unique-constraint violation on the second payer — preventing double-spend.
model InvoicePayment {
  id            String   @id @default(cuid())
  paymentHash   String   @unique
  messageId     String?
  channelId     String?
  payerPubkey   String
  payeePubkey   String?
  amountSats    Int
  paidAt        DateTime @default(now())

  @@index([messageId])
  @@index([channelId])
}

// Pivot table: which members hold which custom roles.
model MemberCustomRole {
  id       String @id @default(cuid())
  memberId String
  roleId   String

  member Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@index([memberId])
  @@index([roleId])
}
