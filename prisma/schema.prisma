generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Server {
  id         String    @id @default(cuid())
  name       String
  icon       String?
  banner     String?
  ownerPubkey String
  joinMode   String    @default("open") // open | invite-only
  createdAt  DateTime  @default(now())

  // Web of Trust (anti-spam): when wotEnabled, only users followed by referentePubkey
  // (or in WotOverride, or holding a valid invite) can join. joinMode is ignored.
  referentePubkey    String?
  wotEnabled         Boolean   @default(false)
  referenteFetchedAt DateTime?

  // Activity-based invite credits policy
  minDaysActive     Int @default(7)
  minMessages       Int @default(20)
  invitesPerUser    Int @default(3)
  inviteExpiryHours Int @default(168) // 7 days

  categories Category[]
  channels   Channel[]
  members    Member[]
  bans       Ban[]
  mutes      Mute[]
  warnings   Warning[]
  reports    Report[]
  moderationActions ModerationAction[]
  invitations      Invitation[]
  wotEntries       WotEntry[]
  wotOverrides     WotOverride[]
}

model DirectMessageThread {
  id           String   @id @default(cuid())
  participant1 String   // pubkey (sorted: participant1 < participant2)
  participant2 String
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([participant1, participant2])
  @@index([participant1])
  @@index([participant2])
}

model Invitation {
  id           String    @id @default(cuid())
  serverId     String
  code         String    @unique
  createdBy    String    // pubkey of inviter
  targetPubkey String?   // null = anyone, set = specific npub
  maxUses      Int       @default(1)
  uses         Int       @default(0)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([code])
}

model Category {
  id       String    @id @default(cuid())
  serverId String
  name     String
  position Int       @default(0)

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels Channel[]

  @@index([serverId])
}

model Channel {
  id         String    @id @default(cuid())
  serverId   String
  categoryId String?
  name       String
  emoji      String?
  type       String    @default("text") // text | voice | forum
  position   Int       @default(0)
  createdAt  DateTime  @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages     Message[]
  voiceStates  VoiceState[]
  forumTags    ForumTag[]
  readStates   ChannelReadState[]

  @@index([serverId])
  @@index([categoryId])
}

model VoiceState {
  id        String   @id @default(cuid())
  channelId String
  pubkey    String
  muted     Boolean  @default(false)
  deafened  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, pubkey])
  @@index([channelId])
}

model Message {
  id           String    @id @default(cuid())
  channelId    String
  authorPubkey String
  title        String?   // null for chat messages, set for forum posts
  content      String
  replyToId    String?
  createdAt    DateTime  @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo   Message?   @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]  @relation("MessageReplies")
  reports   Report[]
  reactions Reaction[]
  tags      ForumTagOnMessage[]
  mentions  Mention[]

  @@index([channelId, createdAt])
  @@index([authorPubkey])
}

model Reaction {
  id           String   @id @default(cuid())
  messageId    String
  authorPubkey String
  emoji        String
  createdAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, authorPubkey, emoji])
  @@index([messageId])
}

model ForumTag {
  id        String @id @default(cuid())
  channelId String
  name      String
  color     String @default("#b4f953") // hex color for the tag pill
  position  Int    @default(0)

  channel  Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ForumTagOnMessage[]

  @@unique([channelId, name])
  @@index([channelId])
}

model ForumTagOnMessage {
  id        String @id @default(cuid())
  messageId String
  tagId     String

  message Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tag     ForumTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([messageId, tagId])
  @@index([messageId])
  @@index([tagId])
}

model Member {
  id       String   @id @default(cuid())
  serverId String
  pubkey   String
  role     String   @default("member") // owner | admin | mod | member
  joinedAt DateTime @default(now())

  // Cached Nostr profile data
  displayName      String?
  picture          String?
  nip05            String?
  about            String?
  banner           String?
  lud16            String?
  website          String?
  nickname         String?  // Obelisk-local server nickname override
  profileUpdatedAt DateTime?

  // Activity tracking for invite-credit eligibility (anti-sybil)
  lastActivityAt   DateTime?

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
  @@index([pubkey])
}

model Session {
  id        String   @id @default(cuid())
  pubkey    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([pubkey])
  @@index([token])
}

model Ban {
  id            String   @id @default(cuid())
  serverId      String
  pubkey        String
  bannedByPubkey String
  reason        String?
  createdAt     DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
}

model Mute {
  id            String   @id @default(cuid())
  serverId      String
  targetPubkey  String
  mutedByPubkey String
  expiresAt     DateTime
  reason        String?
  createdAt     DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, targetPubkey])
}

model Warning {
  id             String   @id @default(cuid())
  serverId       String
  targetPubkey   String
  issuedByPubkey String
  reason         String
  createdAt      DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, targetPubkey])
}

model Report {
  id              String    @id @default(cuid())
  serverId        String
  messageId       String
  reporterPubkey  String
  reason          String
  status          String    @default("pending") // pending | resolved | dismissed
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedByPubkey String?

  server  Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
}

model ModerationAction {
  id           String   @id @default(cuid())
  serverId     String
  actorPubkey  String
  targetPubkey String?
  action       String   // ban | unban | kick | mute | unmute | warn | delete_message | role_change
  reason       String?
  metadata     String?  // JSON string for extra data
  createdAt    DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

model ChannelReadState {
  id                String   @id @default(cuid())
  channelId         String
  pubkey            String
  lastReadAt        DateTime @default(now())
  lastReadMessageId String?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, pubkey])
  @@index([pubkey])
}

model Mention {
  id        String   @id @default(cuid())
  messageId String
  pubkey    String
  channelId String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, pubkey])
  @@index([pubkey, createdAt])
  @@index([channelId, pubkey])
}

model DMReadState {
  id           String   @id @default(cuid())
  pubkey       String
  threadPubkey String
  lastReadAt   DateTime @default(now())

  @@unique([pubkey, threadPubkey])
}

// Cached follow list of a server's referente. Refreshed lazily on login + by admin.
model WotEntry {
  id        String   @id @default(cuid())
  serverId  String
  pubkey    String
  addedAt   DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
  @@index([pubkey])
}

// Manual whitelist for npubs not in the referente's WoT but explicitly allowed by admins.
model WotOverride {
  id        String   @id @default(cuid())
  serverId  String
  pubkey    String
  addedBy   String
  reason    String?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, pubkey])
  @@index([serverId])
}
