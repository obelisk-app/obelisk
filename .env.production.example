# Domain — point DNS A record to your server IP before deploying
DOMAIN=obelisk.yourdomain.com

# PostgreSQL credentials
POSTGRES_USER=obelisk
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=obelisk

# Optional: LiveKit SFU for large voice rooms (50+ participants with video/screen).
# Leave unset to use only the P2P mesh backend (good for up to ~8 participants).
# Start the livekit container with: docker compose --profile livekit up -d
#
# LIVEKIT_URL is the public WSS URL reachable from browsers (typically proxied
# via Caddy — add a reverse_proxy block to the Caddyfile for /livekit).
# Browser-side code also reads NEXT_PUBLIC_LIVEKIT_URL from this same value.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: override the wallet Quick-Setup provisioning instance.
# Defaults to https://zaps.nostr-wot.com when unset. Set this to point at a
# self-hosted nostr-wot provisioning proxy or a local http://localhost:NNNN
# instance during development. Browser-side code reads it directly.
NEXT_PUBLIC_NOSTR_WOT_PROVISION_URL=
