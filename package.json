{
  "name": "obeliskord",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local scripts/dev.mjs",
    "dev:next": "next dev",
    "dev:raise": "./scripts/dev-raise.sh",
    "raise": "./scripts/raise.sh",
    "deploy": "./scripts/deploy.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=scripts/e2e/playwright.config.ts",
    "test:e2e:headed": "HEADED=1 playwright test --config=scripts/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@noble/hashes": "^2.0.1",
