    "@nostr-dev-kit/ndk": "^3.0.3",
    "@nostr-dev-kit/ndk-cache-dexie": "^2.6.44",
    "@nostr-wot/data": "file:../nostr-wot-sdk/packages/data",
    "@nostr-wot/signers": "file:../nostr-wot-sdk/packages/signers",
    "@nostr-wot/ui": "file:../nostr-wot-sdk/packages/ui",
    "emoji-mart": "^5.6.0",
    "gray-matter": "^4.0.3",
    "light-bolt11-decoder": "^3.2.0",
    "mediasoup-client": "^3.20.0",
    "next": "16.2.2",
    "next-mdx-remote": "^5.0.0",
    "nostr-tools": "^2.23.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
